set number
set nowrap
set relativenumber
set tabstop=4 softtabstop=4
set expandtab
set smartindent
set exrc "auto sourcing of init.vim files
set guicursor:
set hidden
set noerrorbells
set smartcase
set nu
set scrolloff=8
set nohlsearch

set noswapfile
set undodir=~/.vim/undodir
set undofile
set nobackup

set incsearch
set ignorecase
set signcolumn=yes
set colorcolumn=80
set cmdheight=2

set updatetime=50
set shortmess+=c

noremap y "+y
noremap p "+p

colorscheme torte

